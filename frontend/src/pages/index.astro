---
import Layout from '../layouts/Layout.astro';
import ChatWidget from '../components/ChatWidget.astro'; // Unser Modul!
---

<Layout title="Sinan.AI - Home">
  
  <main class="w-full h-[calc(100vh-64px)] flex flex-col items-center justify-center p-4 relative overflow-hidden">
    
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-blue-900/20 via-slate-950 to-slate-950 pointer-events-none"></div>

    <div class="z-10 w-full max-w-5xl flex flex-col md:flex-row items-center gap-8 md:gap-16">
      
      <div class="flex-1 text-center md:text-left space-y-6">
        <div class="inline-block bg-blue-900/30 text-blue-300 px-3 py-1 rounded-full text-xs font-bold tracking-widest uppercase border border-blue-500/30">
          AI-Powered Portfolio
        </div>
        
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight">
          Hi, ich bin <span class="bg-gradient-to-r from-blue-400 to-emerald-400 text-transparent bg-clip-text">Sinan</span>.
        </h1>
        
        <p class="text-xl text-slate-400 leading-relaxed">
          Diplom-Informatiker & Solutions Architect. <br/>
          Ich verbinde komplexe Enterprise-Systeme mit moderner AI-Technologie.
        </p>

        <div class="flex gap-4 justify-center md:justify-start pt-4">
            <a href="/cv" class="px-6 py-3 bg-white text-slate-900 font-bold rounded hover:bg-slate-200 transition-colors">
                Zum Lebenslauf
            </a>
            <a href="/projects" class="px-6 py-3 border border-slate-700 text-white rounded hover:border-emerald-500 hover:text-emerald-400 transition-all">
                Projekte ansehen
            </a>
        </div>
      </div>

      <div class="flex-1 w-full max-w-md h-[500px] md:h-[600px]">
        <ChatWidget />
      </div>

    </div>

  </main>
</Layout>