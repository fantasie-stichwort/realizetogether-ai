---
const currentPath = Astro.url.pathname;

// Prüfen, ob wir im englischen Bereich sind
const isEn = currentPath.startsWith('/en');

// Logik für den Sprachwechsel:
// Wenn wir auf "/en/ai" sind -> Wechsel zu "/ai"
// Wenn wir auf "/ai" sind -> Wechsel zu "/en/ai"
let deLink = currentPath.replace('/en', '');
if (deLink === '') deLink = '/'; // Home-Fix

let enLink = '/en' + currentPath;
if (isEn) enLink = currentPath; // Falls schon englisch, nichts tun (wird eh ausgeblendet)
if (currentPath === '/') enLink = '/en'; // Home-Fix

// Navigation Links basierend auf Sprache
const nav = {
  home: isEn ? "/en" : "/",
  profile: isEn ? "/en#profile" : "/#profile",
  cv: isEn ? "/en#resume" : "/#lebenslauf",
  projects: isEn ? "/en#projects" : "/#projekte",
  ai: isEn ? "/en/ai" : "/ai",
  contact: isEn ? "/en#contact" : "/#kontakt",
  // Labels
  l_home: isEn ? "Home" : "Home",
  l_profile: isEn ? "Profile" : "Profil",
  l_cv: isEn ? "Resume" : "Lebenslauf",
  l_projects: isEn ? "Projects" : "Projekte",
  l_ai: "AI Showcase",
  l_contact: isEn ? "Contact" : "Kontakt"
};
---

<nav class="fixed w-full z-50 top-0 transition-all duration-300 backdrop-blur-md bg-slate-900/80 border-b border-white/5" id="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      
      <div class="flex-shrink-0">
        <a href={nav.home} class="text-2xl font-bold font-mono tracking-tighter hover:text-blue-400 transition-colors">
          <span class="text-blue-500">Sinan</span>.AI
        </a>
      </div>
      
      <div class="hidden md:block">
        <div class="ml-10 flex items-baseline space-x-8">
          <a href={nav.home} class="hover:text-blue-400 transition-colors px-3 py-2 rounded-md text-sm font-medium">{nav.l_home}</a>
          <a href={nav.profile} class="hover:text-blue-400 transition-colors px-3 py-2 rounded-md text-sm font-medium">{nav.l_profile}</a>
          <a href={nav.cv} class="hover:text-blue-400 transition-colors px-3 py-2 rounded-md text-sm font-medium">{nav.l_cv}</a>
          <a href={nav.projects} class="hover:text-blue-400 transition-colors px-3 py-2 rounded-md text-sm font-medium">{nav.l_projects}</a>
          
          <a href={nav.ai} class="bg-slate-800 hover:bg-slate-700 text-green-400 border border-green-500/30 px-3 py-2 rounded-md text-sm font-bold transition-all shadow-lg shadow-green-900/20">
            {nav.l_ai}
          </a>

          <a href={nav.contact} class="hover:text-blue-400 transition-colors px-3 py-2 rounded-md text-sm font-medium">{nav.l_contact}</a>

          <div class="ml-4 flex items-center gap-2 border-l border-slate-700 pl-4 font-mono text-sm">
            <a 
              href={deLink} 
              class={`transition-colors ${!isEn ? 'text-blue-400 font-bold cursor-default' : 'text-slate-500 hover:text-white'}`}
            >
              DE
            </a>
            
            <span class="text-slate-700">|</span>
            
            <a 
              href={enLink} 
              class={`transition-colors ${isEn ? 'text-blue-400 font-bold cursor-default' : 'text-slate-500 hover:text-white'}`}
            >
              EN
            </a>
          </div>

        </div>
      </div>
      
      <div class="-mr-2 flex md:hidden">
        <button type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-white hover:bg-gray-700 focus:outline-none" aria-controls="mobile-menu" aria-expanded="false" id="mobile-menu-btn">
          <span class="sr-only">Open main menu</span>
          <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div class="md:hidden hidden bg-slate-900 border-b border-slate-800" id="mobile-menu">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <a href={nav.home} class="text-gray-300 hover:text-white block px-3 py-2 rounded-md text-base font-medium">{nav.l_home}</a>
      <a href={nav.ai} class="text-green-400 hover:text-green-300 block px-3 py-2 rounded-md text-base font-medium">{nav.l_ai}</a>
      
      <div class="flex items-center gap-4 px-3 py-4 border-t border-slate-800 mt-2">
         <a href={deLink} class={`${!isEn ? 'text-blue-400 font-bold' : 'text-slate-500'}`}>DE</a>
         <a href={enLink} class={`${isEn ? 'text-blue-400 font-bold' : 'text-slate-500'}`}>EN</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>