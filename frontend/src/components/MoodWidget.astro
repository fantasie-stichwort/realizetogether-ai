---
const { lang = 'de' } = Astro.props;
const API_URL = import.meta.env.PUBLIC_API_URL;

// Texte basierend auf Sprache
const t = {
  de: {
    title: "AI Stimmungs-Barometer",
    desc: "Schreibe eine Nachricht und lass die KI analysieren, wie sie wirkt.",
    placeholder: "Gib hier deinen Text ein (z.B. eine E-Mail oder Chat-Nachricht)...",
    btn: "Analysieren",
    emotion: "Erkannte Emotion:",
    tip: "KI TIPP:",
    tech: "Technik: Pydantic v2, LangChain, FastAPI. Die KI analysiert nicht nur Text, sondern liefert garantiertes JSON für die Weiterverarbeitung."
  },
  en: {
    title: "AI Mood Barometer",
    desc: "Write a message and let the AI analyze its emotional impact.",
    placeholder: "Enter your text here (e.g., an email or chat message)...",
    btn: "Analyze",
    emotion: "Detected Emotion:",
    tip: "AI TIP:",
    tech: "Tech Stack: Pydantic v2, LangChain, FastAPI. The AI analyzes text and delivers guaranteed JSON structured output."
  }
};

const text = lang === 'en' ? t.en : t.de;
---

<div class="bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl h-full flex flex-col">
  <h3 class="text-xl font-bold text-white mb-2 flex items-center gap-2">
    🎭 {text.title}
  </h3>
  <p class="text-slate-400 text-sm mb-4">
    {text.desc}
  </p>

  <div class="flex-grow flex flex-col gap-4">
    <textarea 
      id={`mood-input-${lang}`}
      class="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white focus:ring-2 focus:ring-blue-500 outline-none resize-none h-32"
      placeholder={text.placeholder}
    ></textarea>
    
    <button 
      id={`mood-btn-${lang}`}
      class="w-full bg-blue-600 hover:bg-blue-500 text-white font-medium py-2 px-4 rounded-lg transition-colors"
    >
      {text.btn}
    </button>
  </div>

  <div id={`mood-result-${lang}`} class="hidden mt-6 pt-4 border-t border-slate-700 animate-fade-in">
    <div class="flex justify-between items-center mb-2">
      <span class="text-slate-400 text-sm">{text.emotion}</span>
      <span id={`mood-badge-${lang}`} class="px-2 py-1 bg-slate-700 rounded text-xs font-bold uppercase tracking-wider text-white">
        UNDEFINED
      </span>
    </div>

    <div class="w-full bg-slate-700 rounded-full h-2.5 mb-4">
      <div id={`mood-bar-${lang}`} class="bg-blue-500 h-2.5 rounded-full transition-all duration-1000" style="width: 50%"></div>
    </div>
    <div class="flex justify-between text-xs text-slate-500 mb-4">
      <span>NEGATIV</span>
      <span>POSITIV</span>
    </div>

    <div class="bg-slate-900/50 p-3 rounded border-l-4 border-yellow-500">
      <p class="text-yellow-500 text-xs font-bold mb-1">💡 {text.tip}</p>
      <p id={`mood-tip-${lang}`} class="text-slate-300 text-sm italic">undefined</p>
    </div>
  </div>
</div>

<div class="mt-4 p-4 bg-slate-900/50 rounded-lg border border-slate-800 text-sm text-slate-400">
  <strong class="text-blue-400">Technik:</strong> {text.tech}
</div>

<script define:vars={{ API_URL, lang }}>
  const btn = document.getElementById(`mood-btn-${lang}`);
  const input = document.getElementById(`mood-input-${lang}`);
  const resultArea = document.getElementById(`mood-result-${lang}`);
  const badge = document.getElementById(`mood-badge-${lang}`);
  const bar = document.getElementById(`mood-bar-${lang}`);
  const tipText = document.getElementById(`mood-tip-${lang}`);

  btn.addEventListener('click', async () => {
    const text = input.value;
    if (!text) return;

    btn.disabled = true;
    btn.innerHTML = lang === 'en' ? "Analyzing..." : "Analysiere...";
    
    try {
      // WICHTIG: Nutzt den korrekten /api/analyze Endpunkt
      const res = await fetch(`${API_URL}/api/analyze`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, language: lang })
      });
      
      const data = await res.json();
      
      if (data.score !== undefined) {
        // Update UI
        badge.innerText = data.emotion;
        
        // Score von -1 bis 1 auf 0% bis 100% mappen
        const percentage = ((data.score + 1) / 2) * 100;
        bar.style.width = `${percentage}%`;
        
        // Farbe je nach Emotion
        if (data.score > 0.3) {
            bar.className = "bg-green-500 h-2.5 rounded-full transition-all duration-1000";
            badge.className = "px-2 py-1 bg-green-900 text-green-300 rounded text-xs font-bold uppercase";
        } else if (data.score < -0.3) {
            bar.className = "bg-red-500 h-2.5 rounded-full transition-all duration-1000";
            badge.className = "px-2 py-1 bg-red-900 text-red-300 rounded text-xs font-bold uppercase";
        } else {
            bar.className = "bg-yellow-500 h-2.5 rounded-full transition-all duration-1000";
            badge.className = "px-2 py-1 bg-yellow-900 text-yellow-300 rounded text-xs font-bold uppercase";
        }

        tipText.innerText = data.suggestion;
        resultArea.classList.remove('hidden');
      }
    } catch (e) {
      console.error(e);
      alert(lang === 'en' ? "Error connecting to AI." : "Fehler bei der Verbindung zur KI.");
    } finally {
      btn.disabled = false;
      btn.innerText = lang === 'en' ? "Analyze" : "Analysieren";
    }
  });
</script>